linters: lintr::all_linters(
        indentation_linter = lintr::indentation_linter(indent = 4L),
        # line_length_linter = lintr::line_length_linter(80L),
        line_length_linter = lintr::line_length_linter(120L),
        library_call_linter = NULL,
        return_linter = NULL,
        cyclocomp_linter = lintr::cyclocomp_linter(complexity_limit = 65L),
        object_length_linter = NULL,
        object_name_linter = NULL,
        commented_code_linter = NULL,
        implicit_integer_linter = NULL,
        one_call_pipe_linter = NULL,
        object_usage_linter = NULL,
        nonportable_path_linter = NULL,
        undesirable_function_linter = NULL,
        nested_pipe_linter = NULL,
        function_argument_linter = NULL,
        condition_call_linter = NULL,
        object_overwrite_linter = NULL
    )
encoding: "UTF-8"
exclusions: list(
    "vignettes/process.R" = list(
        unused_import_linter = Inf
    ),
    "vignettes/process.qmd" = list(
        unused_import_linter = Inf
    ),
    "tests/testthat.R" = list(
        unused_import_linter = Inf
    )
  )
